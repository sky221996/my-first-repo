"""
Simple program to push files to GitHub
"""

import os
import subprocess
import sys
from pathlib import Path


def run_command(cmd, cwd=None):
    """Execute a shell command and return the result"""
    try:
        result = subprocess.run(
            cmd,
            shell=True,
            cwd=cwd,
            capture_output=True,
            text=True,
            check=True
        )
        print(f"✓ {result.stdout.strip()}")
        return True
    except subprocess.CalledProcessError as e:
        print(f"✗ Error: {e.stderr.strip()}")
        return False


def push_to_github(repo_path, commit_message, branch="main"):
    """
    Push changes to GitHub repository
    
    Args:
        repo_path: Path to the local repository
        commit_message: Commit message for the push
        branch: Branch to push to (default: main)
    """
    
    repo_path = Path(repo_path).resolve()
    
    if not repo_path.exists():
        print(f"✗ Repository path does not exist: {repo_path}")
        return False
    
    if not (repo_path / ".git").exists():
        print(f"✗ Not a git repository: {repo_path}")
        return False
    
    print(f"📁 Working in: {repo_path}")
    print(f"🌿 Branch: {branch}")
    
    # Stage changes
    print("\n📝 Staging changes...")
    if not run_command("git add .", cwd=repo_path):
        return False
    
    # Check if there are changes to commit
    print("\n🔍 Checking for changes...")
    result = subprocess.run(
        "git status --porcelain",
        shell=True,
        cwd=repo_path,
        capture_output=True,
        text=True
    )
    
    if not result.stdout.strip():
        print("ℹ No changes to commit")
        return True
    
    # Commit changes
    print("\n💾 Committing changes...")
    if not run_command(f'git commit -m "{commit_message}"', cwd=repo_path):
        return False
    
    # Push to GitHub
    print("\n🚀 Pushing to GitHub...")
    if not run_command(f"git push origin {branch}", cwd=repo_path):
        return False
    
    print("\n✅ Successfully pushed to GitHub!")
    return True


def main():
    """Main function"""
    if len(sys.argv) < 3:
        print("Usage: python push_to_github.py <repo_path> <commit_message> [branch]")
        print("\nExample:")
        print('  python push_to_github.py . "Add new feature" main')
        sys.exit(1)
    
    repo_path = sys.argv[1]
    commit_message = sys.argv[2]
    branch = sys.argv[3] if len(sys.argv) > 3 else "main"
    
    success = push_to_github(repo_path, commit_message, branch)
    sys.exit(0 if success else 1)


if __name__ == "__main__":
    main()
